# --- Obligatorio para la tienda persistente ---
# Conexión a MongoDB (local o Atlas). Con esta variable la tienda guarda
# productos, categorías, pedidos y sesiones. Sin ella arranca en modo demo.
MONGODB_URI="mongodb+srv://usuario:password@cluster0.xxxxx.mongodb.net/ecommerce?retryWrites=true&w=majority"

# Firma de las cookies de sesión. Cualquier texto largo y aleatorio.
SESSION_SECRET="cambia-esto-por-un-texto-largo-al-azar"


# --- Opcional: credenciales del administrador que crea "npm run seed" ---
# Si no las pones se usa admin@demo.com / demo1234
ADMIN_NAME="Administrador"
ADMIN_EMAIL="admin@demo.com"
ADMIN_PASSWORD="demo1234"


# --- Opcional: Cloudinary ---
# Sin estas variables las imágenes se generan como SVG a partir del nombre del
# producto y el formulario no pide subir archivo.
CLOUD_NAME="XXXXXXXXXXX"
API_KEY="XXXXXXXXXXX"
API_SECRET="XXXXXXXXXXX"


# --- Opcional: correo (Mailtrap) ---
# Sin estas variables los pedidos se guardan igual y solo se registran en
# consola; las cuentas nuevas quedan confirmadas automáticamente y la
# recuperación de contraseña queda desactivada.
EMAIL_SERVICE="XXXXXXXXXXX"
HOST_MAILTRAP="XXXXXXXXXXX"
PORT_MAILTRAP="XXXXXXXXXXX"
USER_MAILTRAP="XXXXXXXXXXX"
PASS_MAILTRAP="XXXXXXXXXXX"

# URL pública del sitio, usada en los enlaces de los correos
URLPRODUCCION="https://tu-proyecto.vercel.app"
